#: app/templates/about.html:77
#, python-format
msgid ""
"<strong class=\"text-red-700\">Critical</strong> — below 20% capacity. "
"Evaporation\n"
"                    losses accelerate, water quality degrades, and dams "
"may approach dead storage. Agricultural\n"
"                    allocations are typically cut and municipal rationing"
" may be introduced."
msgstr ""
"<strong class=\"text-red-700\">Kriittinen</strong> — alle 20 % kapasiteetista. "
"Haihtumis-\n"
"                    häviöt kiihtyvät, vedenlaatu heikkenee ja padot "
"saattavat lähestyä kuollutta varastoa. Maatalous-\n"
"                    kiintiöitä leikataan yleensä ja kunnallinen säännöstely"
" voidaan ottaa käyttöön."

#: app/templates/about.html:83
#, python-format
msgid ""
"<strong class=\"text-amber-700\">Warning</strong> — 20 to 40% capacity. "
"Reserves are\n"
"                    reduced and conservation measures are advised. "
"Desalination output may increase to compensate."
msgstr ""
"<strong class=\"text-amber-700\">Varoitus</strong> — 20–40 % kapasiteetista. "
"Varannot ovat\n"
"                    vähentyneet ja säästötoimenpiteitä suositellaan. "
"Suolanpoiston tuotantoa voidaan lisätä korvaamaan vajaus."

#: app/templates/about.html:88
#, python-format
msgid ""
"<strong class=\"text-emerald-700\">Healthy</strong> — above 40% capacity."
" Normal\n"
"                    operational levels with full allocations and "
"sufficient reserves."
msgstr ""
"<strong class=\"text-emerald-700\">Normaali</strong> — yli 40 % kapasiteetista."
" Normaalit\n"
"                    käyttötasot täysillä kiintiöillä ja riittävillä"
" varannoilla."

