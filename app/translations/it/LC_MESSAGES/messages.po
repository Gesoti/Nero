#: app/templates/about.html:163
#, python-format
msgid ""
"<strong class=\"text-red-700\">Critical</strong> — below 20% capacity. "
"Evaporation\n"
"                    losses accelerate, water quality degrades, and dams "
"may approach dead storage. Agricultural\n"
"                    allocations are typically cut and municipal rationing"
" may be introduced."
msgstr ""
"<strong class=\"text-red-700\">Critico</strong> — sotto il 20% della "
"capacità. Le perdite\n"
"                    per evaporazione accelerano, la qualità dell'acqua "
"degrada e le dighe possono avvicinarsi alla riserva morta. Le quote\n"
"                    agricole vengono solitamente ridotte e il "
"razionamento municipale può essere introdotto."

#: app/templates/about.html:169
#, python-format
msgid ""
"<strong class=\"text-amber-700\">Warning</strong> — 20 to 40% capacity. "
"Reserves are\n"
"                    reduced and conservation measures are advised. "
"Desalination output may increase to compensate."
msgstr ""
"<strong class=\"text-amber-700\">Attenzione</strong> — dal 20 al 40% "
"della capacità. Le riserve sono\n"
"                    ridotte e si raccomandano misure di conservazione. La"
" produzione di desalinizzazione potrebbe aumentare per compensare."

#: app/templates/about.html:174
#, python-format
msgid ""
"<strong class=\"text-emerald-700\">Healthy</strong> — above 40% capacity."
" Normal\n"
"                    operational levels with full allocations and "
"sufficient reserves."
msgstr ""
"<strong class=\"text-emerald-700\">Normale</strong> — oltre il 40% della "
"capacità. Livelli\n"
"                    operativi normali con quote complete e riserve "
"sufficienti."

