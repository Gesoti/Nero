#: app/templates/about.html:77
#, python-format
msgid ""
"<strong class=\"text-red-700\">Critical</strong> — below 20% capacity. "
"Evaporation\n"
"                    losses accelerate, water quality degrades, and dams "
"may approach dead storage. Agricultural\n"
"                    allocations are typically cut and municipal rationing"
" may be introduced."
msgstr ""
"<strong class=\"text-red-700\">Kritický</strong> — pod 20 % kapacity. "
"Ztráty\n"
"                    výparem se zrychlují, kvalita vody se zhoršuje a přehrady "
"se mohou blížit mrtvému objemu. Zemědělské\n"
"                    přídělky jsou zpravidla omezeny a může být zavedeno přídělovací hospodaření s vodou."

#: app/templates/about.html:83
#, python-format
msgid ""
"<strong class=\"text-amber-700\">Warning</strong> — 20 to 40% capacity. "
"Reserves are\n"
"                    reduced and conservation measures are advised. "
"Desalination output may increase to compensate."
msgstr ""
"<strong class=\"text-amber-700\">Varování</strong> — 20 až 40 % kapacity. "
"Zásoby jsou\n"
"                    sníženy a doporučují se úsporná opatření. "
"Výroba odsolené vody může být navýšena jako kompenzace."

#: app/templates/about.html:88
#, python-format
msgid ""
"<strong class=\"text-emerald-700\">Healthy</strong> — above 40% capacity."
" Normal\n"
"                    operational levels with full allocations and "
"sufficient reserves."
msgstr ""
"<strong class=\"text-emerald-700\">V pořádku</strong> — nad 40 % kapacity."
" Normální\n"
"                    provozní hladiny s plnými příděly a "
"dostatečnými zásobami."

