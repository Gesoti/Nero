#: app/templates/about.html:163
#, python-format
msgid ""
"<strong class=\"text-red-700\">Critical</strong> — below 20% capacity. "
"Evaporation\n"
"                    losses accelerate, water quality degrades, and dams "
"may approach dead storage. Agricultural\n"
"                    allocations are typically cut and municipal rationing"
" may be introduced."
msgstr ""
"<strong class=\"text-red-700\">Kritisk</strong> — under 20 % kapasitet. "
"Fordampnings-\n"
"                    tap akselererer, vannkvaliteten forringes, og "
"demninger kan nærme seg dødvolum. Jordbruks-\n"
"                    tildelinger kuttes vanligvis og kommunal rasjonering "
"kan bli innført."

#: app/templates/about.html:169
#, python-format
msgid ""
"<strong class=\"text-amber-700\">Warning</strong> — 20 to 40% capacity. "
"Reserves are\n"
"                    reduced and conservation measures are advised. "
"Desalination output may increase to compensate."
msgstr ""
"<strong class=\"text-amber-700\">Advarsel</strong> — 20 til 40 % "
"kapasitet. Reservene er\n"
"                    redusert og bevaringstiltak anbefales. "
"Avsaltingskapasiteten kan økes for å kompensere."

#: app/templates/about.html:174
#, python-format
msgid ""
"<strong class=\"text-emerald-700\">Healthy</strong> — above 40% capacity."
" Normal\n"
"                    operational levels with full allocations and "
"sufficient reserves."
msgstr ""
"<strong class=\"text-emerald-700\">Normal</strong> — over 40 % kapasitet."
" Normale\n"
"                    driftsnivåer med fulle tildelinger og tilstrekkelige "
"reserver."

