# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv

# Application data (created at runtime)
data/

# Environment overrides
.env

# Tailwind standalone CLI binary (downloaded, not committed)
tailwindcss

# Tailwind CSS source entry point (generated artifact, not committed)
app/static/css/input.css

# Terraform
terraform/.terraform/
terraform/*.tfstate
terraform/*.tfstate.backup
terraform/*.tfvars
terraform/.terraform.lock.hcl
terraform/backend.hcl
